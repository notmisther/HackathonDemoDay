---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <style>
    #fileInput {
      display: none !important;
    }

    .eyebrow {
      color: #1a73e8 !important;
    }

    .dropzone {
      border: 2px dashed #1a73e8 !important;
      border-radius: 8px !important;
      padding: 34px 20px !important;
      text-align: center !important;
      cursor: pointer !important;
      background-color: #f8faff !important;
      transition: background 0.2s ease !important;
      min-height: 200px !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
    }

    .dropzone:hover {
      background-color: #e8f0fe !important;
    }

    .dropzone.drag {
      border-color: #1557b0 !important;
      background: #e8f0fe !important;
    }

    .dropzone .folder-icon {
      font-size: 34px !important;
      display: block !important;
      margin-bottom: 10px !important;
    }

    .dropzone strong {
      display: block !important;
      font-size: 15px !important;
      margin-bottom: 4px !important;
      color: #1a73e8 !important;
    }

    .dropzone span {
      font-size: 13px !important;
      color: #80868b !important;
    }

    button.primary {
      background: #1a73e8 !important;
      color: #fff !important;
      border: none !important;
      padding: 12px 24px !important;
      border-radius: 6px !important;
      font-size: 16px !important;
      font-weight: bold !important;
      cursor: pointer !important;
      width: 100% !important;
      transition: background 0.3s ease !important;
    }

    button.primary:hover {
      background: #1557b0 !important;
    }

    button.primary:active {
      transform: translateY(1px) !important;
    }

    button.primary:disabled {
      opacity: 0.45 !important;
      cursor: not-allowed !important;
    }

    #uploadCard > div:last-child {
      display: flex !important;
      justify-content: flex-end !important;
      margin-top: 16px !important;
      width: 100% !important;
    }

    #uploadCard > div:last-child button {
      width: 100% !important;
    }

    /* Modal styles */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .modal-content {
      background: #fff;
      border-radius: 12px;
      padding: 32px;
      max-width: 500px;
      width: 90%;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
      max-height: 90vh;
      overflow-y: auto;
    }

    .modal-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      text-align: center;
    }

    .modal-header h2 {
      margin: 0;
      font-size: 20px;
      color: #d93025;
      font-weight: bold;
    }

    .modal-warning-icon {
      font-size: 28px;
      flex-shrink: 0;
    }

    .modal-body {
      margin-bottom: 24px;
    }

    .modal-body ul {
      margin: 0;
      padding-left: 20px;
      list-style: none;
    }

    .modal-body li {
      margin-bottom: 14px;
      font-size: 14px;
      line-height: 1.6;
      color: #333;
      padding-left: 8px;
      position: relative;
    }

    .modal-body li:before {
      content: "•";
      position: absolute;
      left: 0;
      color: #1a73e8;
      font-weight: bold;
    }

    .modal-footer {
      display: flex;
      gap: 12px;
    }

    .modal-button {
      flex: 1;
      padding: 12px 20px;
      border: none;
      border-radius: 6px;
      font-size: 14px;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    .modal-button-primary {
      background: #1a73e8;
      color: #fff;
    }

    .modal-button-primary:hover {
      background: #1557b0;
    }

    .modal-button-secondary {
      background: #f0f0f0;
      color: #333;
      border: 1px solid #ddd;
    }

    .modal-button-secondary:hover {
      background: #e8e8e8;
    }
  </style>

  <!-- Modal de Advertencia -->
  <div class="modal-overlay" id="warningModal">
    <div class="modal-content">
      <div class="modal-header">
        <span class="modal-warning-icon">⚠️</span>
        <h2>Advertencia Importante</h2>
      </div>
      <div class="modal-body">
        <ul>
          <li>Ten presente las fechas del documento que cargarás en "TRÁMITE CLARO"</li>
          <li>Recuerda: La plataforma es una herramienta de acompañamiento, simplificación e inclusión regulatoria. Sugerimos consultar con un contador o asesor oficial si la falta es grave.</li>
          <li>Ten presente la calidad de la imagen que subas (fotos nítidas funcionan mejor)</li>
        </ul>
      </div>
      <div class="modal-footer">
        <button class="modal-button modal-button-primary" id="closeModalBtn">Entendido</button>
      </div>
    </div>
  </div>

  <div class="hero">
    <div class="eyebrow">01 - EL PROBLEMA</div>
    <p>Un documento de SUNAT o de tu municipalidad no debería costarte una multa por no entenderlo. Sube el PDF o una foto y te decimos, en simple, qué hacer.</p>
  </div>

  <div class="card" id="uploadCard">
    <div class="eyebrow">02 - SUBE TU DOCUMENTO</div>
    <div class="dropzone" id="dropzone">
      <span class="folder-icon" id="folderIcon">📄</span>
      <strong>Arrastra tu PDF o una foto aquí</strong>
      <span>o toca para elegir un archivo — PDF, JPG o PNG de la notificación</span>
    </div>
    <input type="file" id="fileInput" accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/jpeg,image/png" />
    <div id="fileTag"></div>
    <div style="margin-top:16px; display:flex; justify-content:flex-end;">
      <button class="primary" id="analyzeBtn" disabled>Analizar documento</button>
    </div>
  </div>

  <div class="card" id="loaderCard" style="display:none;">
    <div class="loader-row">
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
      <span id="loaderText">Leyendo el documento...</span>
    </div>
  </div>

  <div class="card" id="errorCard" style="display:none;">
    <div class="error-box" id="errorText"></div>
  </div>

  <div class="card" id="resultCard" style="display:none;">
    <div class="steps-header">
      <div class="stamp-seal">LISTO</div>
      <div>
        <div class="eyebrow">03 — TU PLAN DE ACCIÓN</div>
        <div style="font-size:13px;color:#5B6B4C;">Traducido a lenguaje simple</div>
      </div>
    </div>

    <div class="result-col">
      <div class="num">QUÉ SIGNIFICA</div>
      <h3 id="meaningTitle">—</h3>
      <p id="meaningText" style="font-size:14px; line-height:1.55; margin:0;"></p>
    </div>

    <div class="result-col">
      <div class="num">QUÉ DEBES HACER HOY</div>
      <ul id="todoList"></ul>
    </div>

    <div class="result-col">
      <div class="num">QUÉ DOCUMENTOS NECESITAS</div>
      <ul id="docsList"></ul>
    </div>

    <button class="primary" id="downloadBtn" type="button" style="margin-top:6px;">📄 Descargar resumen en PDF</button>
  </div>

  <script type="module">
    // Handle warning modal
    document.addEventListener('DOMContentLoaded', function() {
      const closeModalBtn = document.getElementById('closeModalBtn');
      const warningModal = document.getElementById('warningModal');
      
      if (closeModalBtn) {
        closeModalBtn.addEventListener('click', function() {
          warningModal.style.display = 'none';
        });
      }

      // Close modal when clicking outside
      warningModal.addEventListener('click', function(e) {
        if (e.target === warningModal) {
          warningModal.style.display = 'none';
        }
      });
    });

    import("https://cdn.jsdelivr.net/npm/pdfjs-dist@4.0.379/build/pdf.min.mjs").then((pdfjsLib) => {
      pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdn.jsdelivr.net/npm/pdfjs-dist@4.0.379/build/pdf.worker.min.mjs";
      initializeApp(pdfjsLib);
    }).catch((err) => {
      document.getElementById("errorCard").style.display = "block";
      document.getElementById("errorText").textContent =
        "No se pudo cargar la librería pdf.js desde el CDN (cdn.jsdelivr.net). Revisa tu conexión a internet o si algo la está bloqueando (firewall, extensión del navegador, red corporativa), y recarga la página.";
      console.error(err);
    });

    function initializeApp(pdfjsLib) {
      let extractedText = "";
      let extractedImageBase64 = null;
      let extractedImageMime = null;
      let fileName = "";
      let lastResult = null;

      const $ = (id) => document.getElementById(id);
      const dropzone = $("dropzone");
      const fileInput = $("fileInput");

      dropzone.addEventListener("click", () => fileInput.click());
      ["dragover", "dragenter"].forEach((evt) => {
        dropzone.addEventListener(evt, (e) => {
          e.preventDefault();
          dropzone.classList.add("drag");
        });
      });
      ["dragleave", "drop"].forEach((evt) => {
        dropzone.addEventListener(evt, (e) => {
          e.preventDefault();
          dropzone.classList.remove("drag");
        });
      });
      dropzone.addEventListener("drop", (e) => {
        const file = e.dataTransfer.files[0];
        if (file) handleFile(file);
      });
      fileInput.addEventListener("change", (e) => {
        const file = e.target.files[0];
        if (file) handleFile(file);
      });

      function compressImage(file, maxDim, quality) {
        return new Promise((resolve, reject) => {
          const url = URL.createObjectURL(file);
          const img = new Image();
          img.onload = () => {
            let { width, height } = img;
            if (width > maxDim || height > maxDim) {
              if (width > height) {
                height = Math.round(height * (maxDim / width));
                width = maxDim;
              } else {
                width = Math.round(width * (maxDim / height));
                height = maxDim;
              }
            }
            const canvas = document.createElement("canvas");
            canvas.width = width;
            canvas.height = height;
            canvas.getContext("2d").drawImage(img, 0, 0, width, height);
            URL.revokeObjectURL(url);
            const dataUrl = canvas.toDataURL("image/jpeg", quality);
            resolve(dataUrl.split(",")[1]);
          };
          img.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error("No se pudo leer esta imagen. Prueba con otro archivo (JPG o PNG)."));
          };
          img.src = url;
        });
      }

      function getFileKind(file) {
        const name = (file.name || "").toLowerCase();
        const type = (file.type || "").toLowerCase();
        const isPdf = type === "application/pdf" || name.endsWith(".pdf");
        const isImage =
          type.startsWith("image/") ||
          name.endsWith(".jpg") ||
          name.endsWith(".jpeg") ||
          name.endsWith(".png");

        return { isPdf, isImage };
      }

      async function handleFile(file) {
        const { isPdf: esPdf, isImage: esImagen } = getFileKind(file);

        if (!esPdf && !esImagen) {
          showError("Por favor sube un PDF, JPG o PNG del documento.");
          return;
        }

        fileName = file.name;
        $("folderIcon").textContent = esPdf ? "📄" : "🖼️";
        $("fileTag").innerHTML = `<div class="filename-tag"><span>${esPdf ? "📎" : "🖼️"} ${escapeHtml(fileName)}</span><button type="button" onclick="window.clearFile()">Quitar</button></div>`;

        if (esPdf) {
          extractedImageBase64 = null;
          extractedImageMime = null;
          try {
            const buffer = await file.arrayBuffer();
            const pdf = await pdfjsLib.getDocument({ data: buffer }).promise;
            let text = "";
            for (let i = 1; i <= pdf.numPages; i++) {
              const page = await pdf.getPage(i);
              const content = await page.getTextContent();
              text += content.items.map((it) => it.str).join(" ") + "\n";
            }
            extractedText = text.trim();
            if (!extractedText) {
              showError("No pudimos leer texto de este PDF (puede ser un escaneo/imagen). Prueba con otro archivo o sube una foto del documento.");
              checkReady();
            } else {
              hideError();
              checkReady();
            }
          } catch (err) {
            console.error("Error de pdf.js:", err);
            showError("No se pudo procesar el PDF. Intenta con otro archivo. (Revisa la consola con Cmd+Opt+C para más detalle)");
          }
          return;
        }

        // Es una imagen (foto de la notificación)
        extractedText = "";
        try {
          let base64 = await compressImage(file, 1600, 0.82);
          if (base64.length > 3_500_000) {
            base64 = await compressImage(file, 1200, 0.6);
          }
          extractedImageBase64 = base64;
          extractedImageMime = "image/jpeg";
          hideError();
          checkReady();
        } catch (err) {
          showError(err.message || "No se pudo procesar la imagen. Prueba con otro archivo.");
        }
      }

      window.clearFile = function() {
        extractedText = "";
        extractedImageBase64 = null;
        extractedImageMime = null;
        fileName = "";
        $("fileTag").innerHTML = "";
        $("folderIcon").textContent = "📄";
        checkReady();
      };

      function checkReady() {
        $("analyzeBtn").disabled = !extractedText && !extractedImageBase64;
      }

      function showError(msg) {
        $("errorCard").style.display = "block";
        $("errorText").textContent = msg;
      }

      function hideError() {
        $("errorCard").style.display = "none";
      }

      function escapeHtml(s) {
        return s.replace(/[&<>"']/g, (c) => ({"&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"}[c]));
      }

      $("analyzeBtn").addEventListener("click", analyze);

      async function analyze() {
        hideError();
        $("resultCard").style.display = "none";
        $("loaderCard").style.display = "block";
        $("analyzeBtn").disabled = true;

        const messages = [
          "Leyendo el documento...",
          "Detectando fechas límite y sanciones...",
          "Redactando tu checklist en simple..."
        ];
        let mi = 0;
        const loaderInterval = setInterval(() => {
          mi = (mi + 1) % messages.length;
          $("loaderText").textContent = messages[mi];
        }, 1400);

        try {
          const payload = extractedImageBase64
            ? { image: extractedImageBase64, mimeType: extractedImageMime }
            : { text: extractedText.slice(0, 12000) };

          const response = await fetch("/api/analyze", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
          });

          const responseText = await response.text();
          const contentType = response.headers.get("content-type") || "";
          let parsed = null;
          if (contentType.includes("application/json")) {
            try {
              parsed = JSON.parse(responseText);
            } catch {
              parsed = null;
            }
          }

          if (!response.ok) {
            const serverMessage = parsed?.error || responseText || `Error al conectar con el servidor (${response.status}).`;
            throw new Error(serverMessage);
          }

          if (!parsed) {
            throw new Error("El servidor devolvió una respuesta inesperada. Intenta de nuevo.");
          }

          renderResult(parsed);

        } catch (err) {
          showError(err.message || "Ocurrió un error al analizar el documento.");
        } finally {
          clearInterval(loaderInterval);
          $("loaderCard").style.display = "none";
          $("analyzeBtn").disabled = false;
        }
      }

      function renderResult(parsed) {
        lastResult = parsed;

        $("meaningTitle").textContent = parsed.titulo_significado || "Resumen del documento";
        $("meaningText").textContent = parsed.que_significa || "";

        const todoList = $("todoList");
        todoList.innerHTML = "";
        (parsed.que_hacer_hoy || []).forEach((step) => {
          const li = document.createElement("li");
          li.textContent = step;
          todoList.appendChild(li);
        });

        const docsList = $("docsList");
        docsList.innerHTML = "";
        (parsed.documentos_necesarios || []).forEach((doc) => {
          const li = document.createElement("li");
          li.textContent = doc;
          docsList.appendChild(li);
        });

        // reset stamp animation
        const seal = document.querySelector(".stamp-seal");
        seal.style.animation = "none";
        void seal.offsetWidth;
        seal.style.animation = null;

        $("resultCard").style.display = "block";
        $("resultCard").scrollIntoView({ behavior: "smooth", block: "start" });
      }

      $("downloadBtn").addEventListener("click", descargarResumenPDF);

      function descargarResumenPDF() {
        if (!lastResult || !window.jspdf) {
          showError("No se pudo generar el PDF. Recarga la página e intenta de nuevo.");
          return;
        }

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({ unit: "pt", format: "a4" });
        const marginX = 48;
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        const maxWidth = pageWidth - marginX * 2;
        let y = 64;

        function saltarPaginaSiNecesario(alturaNecesaria) {
          if (y + alturaNecesaria > pageHeight - 60) {
            doc.addPage();
            y = 64;
          }
        }

        doc.setFont("helvetica", "bold");
        doc.setFontSize(18);
        doc.setTextColor(26, 115, 232);
        doc.text("Trámite Claro", marginX, y);
        y += 18;

        doc.setFont("helvetica", "normal");
        doc.setFontSize(10);
        doc.setTextColor(95, 99, 104);
        doc.text("Resumen de tu plan de acción", marginX, y);
        y += 22;

        doc.setDrawColor(224, 224, 224);
        doc.line(marginX, y, pageWidth - marginX, y);
        y += 28;

        doc.setFont("helvetica", "bold");
        doc.setFontSize(13);
        doc.setTextColor(32, 33, 36);
        const titleLines = doc.splitTextToSize(lastResult.titulo_significado || "Resumen del documento", maxWidth);
        saltarPaginaSiNecesario(titleLines.length * 16);
        doc.text(titleLines, marginX, y);
        y += titleLines.length * 16 + 10;

        doc.setFont("helvetica", "normal");
        doc.setFontSize(11);
        doc.setTextColor(95, 99, 104);
        const meaningLines = doc.splitTextToSize(lastResult.que_significa || "", maxWidth);
        saltarPaginaSiNecesario(meaningLines.length * 14);
        doc.text(meaningLines, marginX, y);
        y += meaningLines.length * 14 + 26;

        function seccion(titulo, items) {
          if (!items || !items.length) return;
          saltarPaginaSiNecesario(20);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(11);
          doc.setTextColor(26, 115, 232);
          doc.text(titulo, marginX, y);
          y += 18;

          doc.setFont("helvetica", "normal");
          doc.setFontSize(11);
          doc.setTextColor(51, 51, 51);
          items.forEach((item, i) => {
            const lines = doc.splitTextToSize(`${i + 1}. ${item}`, maxWidth - 10);
            saltarPaginaSiNecesario(lines.length * 14);
            doc.text(lines, marginX + 8, y);
            y += lines.length * 14 + 6;
          });
          y += 14;
        }

        seccion("QUÉ DEBES HACER HOY", lastResult.que_hacer_hoy);
        seccion("QUÉ DOCUMENTOS NECESITAS", lastResult.documentos_necesarios);

        doc.setFont("helvetica", "normal");
        doc.setFontSize(9);
        doc.setTextColor(150, 150, 150);
        doc.text("Generado por Trámite Claro · Este resumen no reemplaza asesoría legal.", marginX, pageHeight - 30);

        const fecha = new Date().toISOString().slice(0, 10);
        doc.save(`resumen-tramite-claro-${fecha}.pdf`);
      }
    }
  </script>
</Layout>
